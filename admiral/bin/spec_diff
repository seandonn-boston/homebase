#!/bin/bash
# Admiral Framework — Spec Diff Tool
# Compares two spec versions and classifies changes.
# Usage: spec_diff [--from <commit>] [--to <commit>] [--json]
# Defaults: --from HEAD~1 --to HEAD
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"

FROM_REF="HEAD~1"
TO_REF="HEAD"
JSON_MODE=false
SPEC_DIR="aiStrat/admiral/spec"
REF_DIR="aiStrat/admiral/reference"

while [ $# -gt 0 ]; do
  case "$1" in
    --from) FROM_REF="$2"; shift 2 ;;
    --to) TO_REF="$2"; shift 2 ;;
    --json) JSON_MODE=true; shift ;;
    *) echo "Usage: spec_diff [--from <commit>] [--to <commit>] [--json]" >&2; exit 1 ;;
  esac
done

cd "$PROJECT_DIR"

# Get changed spec files between the two refs
CHANGED_SPEC=$(git diff --name-only "$FROM_REF" "$TO_REF" -- "$SPEC_DIR" "$REF_DIR" 2>/dev/null) || CHANGED_SPEC=""

if [ -z "$CHANGED_SPEC" ]; then
  if [ "$JSON_MODE" = "true" ]; then
    echo '{"changes":[],"summary":{"total":0,"spec_parts_affected":[],"has_breaking":false}}'
  else
    echo "No spec changes between $FROM_REF and $TO_REF"
  fi
  exit 0
fi

TOTAL=0
PARTS_AFFECTED=""
CHANGES_JSON="[]"

while IFS= read -r file; do
  [ -z "$file" ] && continue
  TOTAL=$((TOTAL + 1))

  # Determine spec part from filename
  PART="unknown"
  BASENAME=$(basename "$file" .md)
  case "$BASENAME" in
    part[0-9]*) PART="$BASENAME" ;;
    reference-constants) PART="reference-constants" ;;
    *) PART="$BASENAME" ;;
  esac

  # Get diff stats
  STATS=$(git diff --stat "$FROM_REF" "$TO_REF" -- "$file" 2>/dev/null | tail -1)
  INSERTIONS=$(echo "$STATS" | grep -oP '\d+(?= insertion)' || echo "0")
  DELETIONS=$(echo "$STATS" | grep -oP '\d+(?= deletion)' || echo "0")

  # Classify change magnitude
  TOTAL_LINES=$((${INSERTIONS:-0} + ${DELETIONS:-0}))
  if [ "$TOTAL_LINES" -le 5 ]; then
    MAGNITUDE="cosmetic"
  elif [ "$TOTAL_LINES" -le 50 ]; then
    MAGNITUDE="minor"
  else
    MAGNITUDE="major"
  fi

  PARTS_AFFECTED="$PARTS_AFFECTED $PART"

  if [ "$JSON_MODE" = "true" ]; then
    ENTRY=$(jq -n \
      --arg file "$file" \
      --arg part "$PART" \
      --argjson ins "${INSERTIONS:-0}" \
      --argjson del "${DELETIONS:-0}" \
      --arg mag "$MAGNITUDE" \
      '{file: $file, spec_part: $part, insertions: $ins, deletions: $del, magnitude: $mag}')
    CHANGES_JSON=$(echo "$CHANGES_JSON" | jq --argjson e "$ENTRY" '. + [$e]')
  else
    echo "  $file (+${INSERTIONS:-0}/-${DELETIONS:-0}) [$MAGNITUDE]"
  fi
done <<< "$CHANGED_SPEC"

# Deduplicate parts
UNIQUE_PARTS=$(echo "$PARTS_AFFECTED" | tr ' ' '\n' | sort -u | grep -v '^$' | tr '\n' ',' | sed 's/,$//')

if [ "$JSON_MODE" = "true" ]; then
  PARTS_ARR=$(echo "$PARTS_AFFECTED" | tr ' ' '\n' | sort -u | grep -v '^$' | jq -R . | jq -s .)
  HAS_MAJOR=$(echo "$CHANGES_JSON" | jq '[.[] | select(.magnitude == "major")] | length > 0')
  jq -n \
    --arg from "$FROM_REF" \
    --arg to "$TO_REF" \
    --argjson changes "$CHANGES_JSON" \
    --argjson total "$TOTAL" \
    --argjson parts "$PARTS_ARR" \
    --argjson breaking "$HAS_MAJOR" \
    '{from: $from, to: $to, changes: $changes, summary: {total: $total, spec_parts_affected: $parts, has_potential_breaking: $breaking}}'
else
  echo ""
  echo "=== Spec Diff: $FROM_REF..$TO_REF ==="
  echo "  Files changed: $TOTAL"
  echo "  Parts affected: $UNIQUE_PARTS"
fi
