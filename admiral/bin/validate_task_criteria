#!/bin/bash
# Admiral Framework — Task Acceptance Criteria Validator (ST-04)
# Validates a task criteria document against required fields.
# Usage: validate_task_criteria [--json] <path-to-task-criteria.json>
# Exit codes: 0=valid, 1=warnings only, 2=hard failures
set -euo pipefail

JSON_MODE=false
DOC=""

for arg in "$@"; do
  case "$arg" in
    --json) JSON_MODE=true ;;
    *) DOC="$arg" ;;
  esac
done

if [ -z "$DOC" ]; then
  echo "Usage: validate_task_criteria [--json] <path-to-task-criteria.json>"
  echo ""
  echo "Validates a task criteria document ensuring all required fields are present"
  echo "and properly populated per Admiral Spec task acceptance requirements."
  echo ""
  echo "Required fields:"
  echo "  task_id, title, functional, quality, completeness,"
  echo "  negative, verification_level, failure_guidance"
  echo ""
  echo "Exit codes:"
  echo "  0  Document is valid"
  echo "  1  Warnings (usable but incomplete)"
  echo "  2  Errors (invalid, must fix)"
  exit 1
fi

if [ ! -f "$DOC" ]; then
  echo "ERROR: File not found: $DOC"
  exit 2
fi

if ! jq empty "$DOC" 2>/dev/null; then
  echo "ERROR: Not valid JSON: $DOC"
  exit 2
fi

ERRORS=()
WARNINGS=()

# --- Helper functions ---

check_required_string() {
  local path="$1"
  local label="$2"
  local val
  val=$(jq -r "$path // empty" "$DOC" 2>/dev/null)
  if [ -z "$val" ]; then
    ERRORS+=("Missing required field: $label ($path)")
  fi
}

check_required_array() {
  local path="$1"
  local label="$2"
  local count
  count=$(jq "$path | length" "$DOC" 2>/dev/null || echo "0")
  if [ "$count" -eq 0 ]; then
    ERRORS+=("Empty required array: $label ($path)")
  fi
}

check_enum() {
  local path="$1"
  local label="$2"
  shift 2
  local allowed=("$@")
  local val
  val=$(jq -r "$path // empty" "$DOC" 2>/dev/null)
  if [ -z "$val" ]; then
    ERRORS+=("Missing required enum: $label ($path)")
    return
  fi
  local found=false
  for a in "${allowed[@]}"; do
    if [ "$val" = "$a" ]; then
      found=true
      break
    fi
  done
  if [ "$found" = false ]; then
    ERRORS+=("Invalid value for $label ($path): '$val' — allowed: ${allowed[*]}")
  fi
}

# --- Required fields ---

check_required_string ".task_id" "task_id"
check_required_string ".title" "title"

# Functional criteria: what the task must accomplish
check_required_array ".functional" "functional"

# Quality criteria: standards the output must meet
check_required_array ".quality" "quality"

# Completeness criteria: what "done" looks like
check_required_array ".completeness" "completeness"

# Negative criteria: what the task must NOT do
check_required_array ".negative" "negative"

# Verification level: how thoroughly to verify
check_enum ".verification_level" "verification_level" \
  "smoke" "standard" "thorough" "exhaustive"

# Failure guidance: what to do when criteria can't be met
check_enum ".failure_guidance" "failure_guidance" \
  "escalate" "deliver_partial_with_explanation" "block_and_report" "retry_with_variation"

# --- Optional but recommended fields ---

# Judgment boundaries: where human/Admiral judgment is needed
jb_count=$(jq '.judgment_boundaries | length' "$DOC" 2>/dev/null || echo "0")
if [ "$jb_count" -eq 0 ]; then
  WARNINGS+=("No judgment_boundaries defined — consider adding boundaries for ambiguous decisions")
fi

# Dependencies: tasks that must complete first
if [ "$(jq 'has("dependencies")' "$DOC" 2>/dev/null)" != "true" ]; then
  WARNINGS+=("No dependencies field — consider listing upstream task dependencies")
fi

# Timeout: maximum time budget for this task
if [ "$(jq 'has("timeout")' "$DOC" 2>/dev/null)" != "true" ]; then
  WARNINGS+=("No timeout field — consider setting a time budget")
fi

# --- Output ---

if [ "$JSON_MODE" = true ]; then
  errors_json=$(printf '%s\n' "${ERRORS[@]}" 2>/dev/null | jq -R . | jq -s . 2>/dev/null || echo "[]")
  warnings_json=$(printf '%s\n' "${WARNINGS[@]}" 2>/dev/null | jq -R . | jq -s . 2>/dev/null || echo "[]")

  if [ ${#ERRORS[@]} -gt 0 ]; then
    status="fail"
  elif [ ${#WARNINGS[@]} -gt 0 ]; then
    status="warn"
  else
    status="pass"
  fi

  jq -n \
    --arg status "$status" \
    --argjson errors "$errors_json" \
    --argjson warnings "$warnings_json" \
    '{status: $status, errors: $errors, warnings: $warnings}'

  if [ ${#ERRORS[@]} -gt 0 ]; then exit 2; fi
  if [ ${#WARNINGS[@]} -gt 0 ]; then exit 1; fi
  exit 0
fi

# Human-readable output
if [ ${#ERRORS[@]} -gt 0 ]; then
  echo "VALIDATION FAILED — ${#ERRORS[@]} error(s):"
  for err in "${ERRORS[@]}"; do
    echo "  ERROR: $err"
  done
  if [ ${#WARNINGS[@]} -gt 0 ]; then
    echo ""
    echo "Warnings (${#WARNINGS[@]}):"
    for w in "${WARNINGS[@]}"; do
      echo "  WARN: $w"
    done
  fi
  exit 2
fi

if [ ${#WARNINGS[@]} -gt 0 ]; then
  echo "VALIDATION PASSED with ${#WARNINGS[@]} warning(s):"
  for w in "${WARNINGS[@]}"; do
    echo "  WARN: $w"
  done
  exit 1
fi

echo "VALIDATION PASSED — Task criteria document is valid."
exit 0
