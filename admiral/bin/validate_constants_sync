#!/bin/bash
# Admiral Framework — Reference Constants Sync Validator
# Verifies JSON registry, shell registry, and config.json are in sync.
# Exits non-zero on any divergence. Intended for CI integration.
# Usage: validate_constants_sync [--ci]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"

JSON_REG="$PROJECT_DIR/admiral/config/reference_constants.json"
SH_REG="$PROJECT_DIR/admiral/config/reference_constants.sh"
CONFIG="$PROJECT_DIR/admiral/config.json"

ERRORS=0
WARNINGS=0

check_json_vs_sh() {
  local json_path="$1"
  local sh_var="$2"
  local label="$3"

  local json_val
  json_val=$(jq -r "$json_path" "$JSON_REG" 2>/dev/null)

  # Source the shell registry in a subshell to get the value
  local sh_val
  sh_val=$(bash -c "source '$SH_REG' 2>/dev/null; echo \"\$$sh_var\"")

  if [ "$json_val" != "$sh_val" ]; then
    echo "  DIVERGENCE: $label — JSON=$json_val, SH=$sh_val"
    ERRORS=$((ERRORS + 1))
  fi
}

check_json_vs_config() {
  local json_path="$1"
  local config_path="$2"
  local label="$3"

  local json_val
  json_val=$(jq -r "$json_path" "$JSON_REG" 2>/dev/null)

  local config_val
  config_val=$(jq -r "$config_path" "$CONFIG" 2>/dev/null)

  if [ "$config_val" = "null" ]; then
    return  # config.json doesn't override this constant
  fi

  if [ "$json_val" != "$config_val" ]; then
    echo "  DIVERGENCE: $label — JSON registry=$json_val, config.json=$config_val"
    ERRORS=$((ERRORS + 1))
  fi
}

# Check files exist
for f in "$JSON_REG" "$SH_REG" "$CONFIG"; do
  if [ ! -f "$f" ]; then
    echo "ERROR: Required file not found: $f"
    exit 1
  fi
done

echo "=== Reference Constants Sync Validation ==="
echo ""

# --- Token Estimates: JSON vs SH ---
echo "--- Token Estimates ---"
check_json_vs_sh '.constants.tool_token_estimates.Bash' 'RC_TOKEN_BASH' 'Bash tokens'
check_json_vs_sh '.constants.tool_token_estimates.Read' 'RC_TOKEN_READ' 'Read tokens'
check_json_vs_sh '.constants.tool_token_estimates.Write' 'RC_TOKEN_WRITE' 'Write tokens'
check_json_vs_sh '.constants.tool_token_estimates.Agent' 'RC_TOKEN_AGENT' 'Agent tokens'
check_json_vs_sh '.constants.tool_token_estimates.default' 'RC_TOKEN_DEFAULT' 'Default tokens'

# --- Token Estimates: JSON vs config.json ---
check_json_vs_config '.constants.tool_token_estimates.Bash' '.tokenEstimates.Bash' 'Bash tokens (config)'
check_json_vs_config '.constants.tool_token_estimates.Read' '.tokenEstimates.Read' 'Read tokens (config)'
check_json_vs_config '.constants.tool_token_estimates.Agent' '.tokenEstimates.Agent' 'Agent tokens (config)'
check_json_vs_config '.constants.tool_token_estimates.default' '.tokenEstimates.default' 'Default tokens (config)'

# --- Loop Detection ---
echo "--- Loop Detection ---"
check_json_vs_sh '.constants.loop_detection.max_same_error' 'RC_MAX_SAME_ERROR' 'Max same error'
check_json_vs_sh '.constants.loop_detection.max_total_errors' 'RC_MAX_TOTAL_ERRORS' 'Max total errors'
check_json_vs_sh '.constants.loop_detection.success_decay' 'RC_SUCCESS_DECAY' 'Success decay'
check_json_vs_config '.constants.loop_detection.max_same_error' '.hooks.maxSameError' 'Max same error (config)'
check_json_vs_config '.constants.loop_detection.max_total_errors' '.hooks.maxTotalErrors' 'Max total errors (config)'

# --- Budget Thresholds ---
echo "--- Budget Thresholds ---"
check_json_vs_sh '.constants.token_budget_thresholds.warning_pct' 'RC_BUDGET_WARNING_PCT' 'Warning %'
check_json_vs_sh '.constants.token_budget_thresholds.escalation_pct' 'RC_BUDGET_ESCALATION_PCT' 'Escalation %'
check_json_vs_config '.constants.token_budget_thresholds.warning_pct' '.hooks.budgetWarningPct' 'Warning % (config)'

# --- Hook Timeouts ---
echo "--- Hook Timeouts ---"
check_json_vs_sh '.constants.hook_timeouts_ms.default' 'RC_HOOK_TIMEOUT_DEFAULT' 'Default timeout'
check_json_vs_sh '.constants.hook_timeouts_ms.budget' 'RC_HOOK_TIMEOUT_BUDGET' 'Budget timeout'
check_json_vs_sh '.constants.hook_timeouts_ms.min' 'RC_HOOK_TIMEOUT_MIN' 'Min timeout'
check_json_vs_sh '.constants.hook_timeouts_ms.max' 'RC_HOOK_TIMEOUT_MAX' 'Max timeout'

# --- Fleet Constants ---
echo "--- Fleet Constants ---"
check_json_vs_sh '.constants.fleet.min_agents' 'RC_FLEET_MIN_AGENTS' 'Min agents'
check_json_vs_sh '.constants.fleet.max_agents' 'RC_FLEET_MAX_AGENTS' 'Max agents'
check_json_vs_sh '.constants.fleet.chunk_budget_ceiling_pct' 'RC_CHUNK_BUDGET_CEILING_PCT' 'Chunk ceiling'

# --- Context ---
echo "--- Context ---"
check_json_vs_sh '.constants.context_ceilings.standing_ceiling_tokens' 'RC_STANDING_CONTEXT_CEILING' 'Standing ceiling'
check_json_vs_sh '.constants.context_health_check.frequency' 'RC_HEALTH_CHECK_FREQUENCY' 'Health check freq'

# --- Brain ---
echo "--- Brain ---"
check_json_vs_sh '.constants.brain_query.default_result_limit' 'RC_BRAIN_DEFAULT_RESULT_LIMIT' 'Brain result limit'
check_json_vs_sh '.constants.brain_query.cosine_min_score' 'RC_BRAIN_COSINE_MIN_SCORE' 'Cosine min score'

echo ""
echo "=== Results: $ERRORS divergences, $WARNINGS warnings ==="

if [ "$ERRORS" -gt 0 ]; then
  echo ""
  echo "FAIL: Constants are out of sync. Fix divergences before merging."
  exit 1
fi

echo "PASS: All checked constants are in sync."
exit 0
