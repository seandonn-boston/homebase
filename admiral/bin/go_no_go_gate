#!/bin/bash
# Admiral Framework — Go/No-Go Deployment Gate (ST-03)
# Invokes readiness assessment and enforces profile restrictions.
# Not Ready projects are blocked. Partially Ready projects are restricted to Starter profile.
# Admiral override with justification is supported and logged.
# Usage: go_no_go_gate [--json] [--admiral-override="justification"] --profile=<name> <project-root> <ground-truth-path>
# Exit codes: 0=Go (deployment allowed), 1=No-Go (blocked)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ADMIRAL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
READINESS="$ADMIRAL_DIR/bin/readiness_assess"
OVERRIDE_LOG="$ADMIRAL_DIR/strategy/override_log.jsonl"

# Valid profiles per spec: Starter → Team → Governed → Production → Enterprise
VALID_PROFILES=("starter" "team" "governed" "production" "enterprise")

JSON_MODE=false
PROFILE=""
OVERRIDE_JUSTIFICATION=""
PROJECT_ROOT=""
GT_PATH=""

for arg in "$@"; do
  case "$arg" in
    --json) JSON_MODE=true ;;
    --profile=*) PROFILE="${arg#--profile=}" ;;
    --admiral-override=*) OVERRIDE_JUSTIFICATION="${arg#--admiral-override=}" ;;
    *)
      if [ -z "$PROJECT_ROOT" ]; then
        PROJECT_ROOT="$arg"
      elif [ -z "$GT_PATH" ]; then
        GT_PATH="$arg"
      fi
      ;;
  esac
done

if [ -z "$PROJECT_ROOT" ] || [ -z "$GT_PATH" ] || [ -z "$PROFILE" ]; then
  echo "Usage: go_no_go_gate [--json] [--admiral-override=\"justification\"] --profile=<name> <project-root> <ground-truth-path>"
  echo ""
  echo "Profiles: starter, team, governed, production, enterprise"
  echo ""
  echo "Decision logic:"
  echo "  Ready          → Any profile allowed (Go)"
  echo "  Partially Ready → Starter only; others blocked (No-Go unless override)"
  echo "  Not Ready      → All blocked (No-Go unless override)"
  echo ""
  echo "Exit codes:"
  echo "  0  Go — deployment allowed"
  echo "  1  No-Go — deployment blocked"
  exit 1
fi

# Normalize profile to lowercase
PROFILE=$(echo "$PROFILE" | tr '[:upper:]' '[:lower:]')

# Validate profile name
valid=false
for p in "${VALID_PROFILES[@]}"; do
  if [ "$PROFILE" = "$p" ]; then
    valid=true
    break
  fi
done

if [ "$valid" = false ]; then
  echo "ERROR: Invalid profile '$PROFILE' — allowed: ${VALID_PROFILES[*]}"
  exit 1
fi

# Run readiness assessment
readiness_rc=0
readiness_output=$("$READINESS" --json "$PROJECT_ROOT" "$GT_PATH" 2>&1) || readiness_rc=$?

readiness_status="unknown"
case $readiness_rc in
  0) readiness_status="Ready" ;;
  1) readiness_status="Partially Ready" ;;
  *) readiness_status="Not Ready" ;;
esac

# Decision logic
decision="go"
reason=""

if [ "$readiness_status" = "Ready" ]; then
  decision="go"
  reason="Project is Ready — all checks passed for profile '$PROFILE'"
elif [ "$readiness_status" = "Partially Ready" ]; then
  if [ "$PROFILE" = "starter" ]; then
    decision="go"
    reason="Project is Partially Ready — allowed for Starter profile only"
  else
    decision="no-go"
    reason="Project is Partially Ready — profile '$PROFILE' requires Ready status (only Starter allowed)"
  fi
else
  decision="no-go"
  reason="Project is Not Ready — deployment blocked for all profiles"
fi

# Handle Admiral override
override_applied=false
if [ "$decision" = "no-go" ] && [ -n "$OVERRIDE_JUSTIFICATION" ]; then
  override_applied=true
  decision="go"
  reason="OVERRIDE: $reason — Admiral override applied with justification"

  # Log override
  mkdir -p "$(dirname "$OVERRIDE_LOG")"
  TRACE_ID=$(uuidgen 2>/dev/null || python3 -c "import uuid; print(uuid.uuid4())" 2>/dev/null || echo "override-$(date +%s)")
  SESSION_ID="${CLAUDE_SESSION_ID:-unknown}"

  jq -cn \
    --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --arg trace "$TRACE_ID" \
    --arg sid "$SESSION_ID" \
    --arg readiness "$readiness_status" \
    --arg profile "$PROFILE" \
    --arg justification "$OVERRIDE_JUSTIFICATION" \
    --arg reason "$reason" \
    '{
      event: "admiral_override",
      timestamp: $ts,
      trace_id: $trace,
      session_id: $sid,
      readiness_state: $readiness,
      requested_profile: $profile,
      override_justification: $justification,
      decision: "go (override)",
      original_decision: "no-go",
      reason: $reason
    }' >> "$OVERRIDE_LOG" 2>/dev/null || true
fi

# Output
if [ "$JSON_MODE" = true ]; then
  jq -n \
    --arg decision "$decision" \
    --arg readiness "$readiness_status" \
    --arg profile "$PROFILE" \
    --arg reason "$reason" \
    --argjson override "$override_applied" \
    --argjson readiness_detail "$readiness_output" \
    '{
      decision: $decision,
      readiness_status: $readiness,
      profile: $profile,
      reason: $reason,
      override_applied: $override,
      readiness_detail: $readiness_detail
    }'
else
  echo "=== Go/No-Go Deployment Gate ==="
  echo ""
  echo "Profile:   $PROFILE"
  echo "Readiness: $readiness_status"
  echo "Decision:  $(echo "$decision" | tr '[:lower:]' '[:upper:]')"
  if [ "$override_applied" = true ]; then
    echo "Override:  YES — $OVERRIDE_JUSTIFICATION"
  fi
  echo ""
  echo "Reason: $reason"
fi

if [ "$decision" = "go" ]; then
  exit 0
else
  exit 1
fi
