#!/bin/bash
# Admiral Framework — Brain Audit (B1)
# Lists entries older than 90 days (decay awareness)
# Usage: brain_audit [--project <name>] [--days <N>]
set -euo pipefail

BRAIN_DIR="${BRAIN_DIR:-${CLAUDE_PROJECT_DIR:-.}/.brain}"

DECAY_DAYS=90
PROJECT=""
SHOW_DEMAND=false

# Parse flags
while [ $# -gt 0 ]; do
  case "$1" in
    --project) PROJECT="$2"; shift 2 ;;
    --days) DECAY_DAYS="$2"; shift 2 ;;
    --demand) SHOW_DEMAND=true; shift ;;
    *) shift ;;
  esac
done

# B-03: Demand signal report
if [ "$SHOW_DEMAND" = true ]; then
  DEMAND_DIR="${BRAIN_DIR}/_demand"
  echo "Brain Demand Signal Report"
  echo "=========================="
  if [ ! -d "$DEMAND_DIR" ] || [ -z "$(ls -A "$DEMAND_DIR" 2>/dev/null)" ]; then
    echo "No demand signals recorded."
    echo ""
    echo "Demand signals are recorded when brain_query returns 0 results."
    echo "This indicates knowledge gaps that may inform Brain B2 graduation."
    exit 0
  fi

  DEMAND_COUNT=0
  UNIQUE_QUERIES=""
  for df in "$DEMAND_DIR"/*.json; do
    [ -f "$df" ] || continue
    DEMAND_COUNT=$((DEMAND_COUNT + 1))
    QUERY=$(jq -r '.query // "unknown"' "$df" 2>/dev/null)
    AGENT=$(jq -r '.agent // "unknown"' "$df" 2>/dev/null)
    TS=$(jq -r '.timestamp // "unknown"' "$df" 2>/dev/null)
    echo "  [$TS] Query: \"$QUERY\" (agent: $AGENT)"
    UNIQUE_QUERIES="${UNIQUE_QUERIES}${QUERY}\n"
  done

  UNIQUE_COUNT=$(echo -e "$UNIQUE_QUERIES" | sort -u | grep -c '[^ ]' || echo 0)
  echo ""
  echo "=========================="
  echo "Total demand signals: $DEMAND_COUNT"
  echo "Unique queries: $UNIQUE_COUNT"
  echo ""
  echo "High-demand queries indicate knowledge gaps worth filling."
  echo "Graduation criteria: advance to B2 when missed retrieval rate >30%."
  exit 0
fi

SEARCH_PATH="$BRAIN_DIR"
if [ -n "$PROJECT" ]; then
  SEARCH_PATH="${BRAIN_DIR}/${PROJECT}"
fi

CUTOFF_DATE=$(date -u -d "-${DECAY_DAYS} days" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u -v-${DECAY_DAYS}d +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "")

TOTAL=0
DECAYED=0
echo "Brain Audit Report"
echo "=================="
echo "Decay threshold: ${DECAY_DAYS} days"
echo ""

ALL_FILES=$(find "$SEARCH_PATH" -name "*.json" -type f 2>/dev/null | sort)

for file in $ALL_FILES; do
  [ -f "$file" ] || continue
  TOTAL=$((TOTAL + 1))

  CREATED=$(jq -r '.created_at' "$file" 2>/dev/null)
  TITLE=$(jq -r '.title' "$file" 2>/dev/null)
  CAT=$(jq -r '.category' "$file" 2>/dev/null)
  PROJ=$(jq -r '.project' "$file" 2>/dev/null)

  # Check if entry is older than cutoff
  if [ -n "$CUTOFF_DATE" ] && [[ "$CREATED" < "$CUTOFF_DATE" ]]; then
    DECAYED=$((DECAYED + 1))
    echo "[DECAY] $TITLE"
    echo "  Category: $CAT | Project: $PROJ | Created: $CREATED"
    echo "  File: $file"
    echo ""
  fi
done

echo "=================="
echo "Total entries: $TOTAL"
echo "Decayed (>${DECAY_DAYS} days): $DECAYED"
if [ "$TOTAL" -gt 0 ]; then
  echo "Decay rate: $((DECAYED * 100 / TOTAL))%"
fi
