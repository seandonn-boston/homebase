#!/bin/bash
# Admiral Framework — Spec Version Manifest Validator
# Validates that spec_version_manifest.json is well-formed and that
# referenced implementation files actually exist.
# Usage: validate_spec_manifest [manifest_path]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
MANIFEST="${1:-$PROJECT_DIR/admiral/config/spec_version_manifest.json}"

if [ ! -f "$MANIFEST" ]; then
  echo "ERROR: Manifest not found at $MANIFEST" >&2
  exit 1
fi

# Validate JSON
if ! jq empty "$MANIFEST" 2>/dev/null; then
  echo "ERROR: Manifest is not valid JSON" >&2
  exit 1
fi

ERRORS=0
WARNINGS=0

# Check required top-level fields
for field in spec_version control_plane_version last_audited components summary; do
  val=$(jq -r ".$field // empty" "$MANIFEST")
  if [ -z "$val" ]; then
    echo "ERROR: Missing required field '$field'" >&2
    ERRORS=$((ERRORS + 1))
  fi
done

# Validate each component
TOTAL=$(jq '.components | length' "$MANIFEST")
echo "Validating $TOTAL components..."

for i in $(seq 0 $((TOTAL - 1))); do
  COMP_ID=$(jq -r ".components[$i].id" "$MANIFEST")
  COMP_FILE=$(jq -r ".components[$i].file" "$MANIFEST")
  COMPLIANCE=$(jq -r ".components[$i].compliance" "$MANIFEST")
  SPEC_PARTS=$(jq -r ".components[$i].spec_parts | length" "$MANIFEST")

  # Check required fields
  if [ "$COMP_ID" = "null" ] || [ -z "$COMP_ID" ]; then
    echo "  ERROR: Component at index $i has no id" >&2
    ERRORS=$((ERRORS + 1))
    continue
  fi

  if [ "$COMPLIANCE" = "null" ] || [ -z "$COMPLIANCE" ]; then
    echo "  ERROR: $COMP_ID has no compliance level" >&2
    ERRORS=$((ERRORS + 1))
  fi

  # Validate compliance value
  case "$COMPLIANCE" in
    full|partial|minimal|none) ;;
    *)
      echo "  ERROR: $COMP_ID has invalid compliance '$COMPLIANCE'" >&2
      ERRORS=$((ERRORS + 1))
      ;;
  esac

  # Check spec_parts not empty
  if [ "$SPEC_PARTS" -eq 0 ]; then
    echo "  ERROR: $COMP_ID has no spec_parts" >&2
    ERRORS=$((ERRORS + 1))
  fi

  # Check files exist (handle comma-separated multi-file entries)
  IFS=',' read -ra FILES <<< "$COMP_FILE"
  for f in "${FILES[@]}"; do
    f=$(echo "$f" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    FULL_PATH="$PROJECT_DIR/$f"
    if [ ! -e "$FULL_PATH" ]; then
      echo "  WARNING: $COMP_ID references '$f' which does not exist" >&2
      WARNINGS=$((WARNINGS + 1))
    fi
  done
done

# Validate summary counts match
EXPECTED_TOTAL=$(jq '.components | length' "$MANIFEST")
SUMMARY_TOTAL=$(jq '.summary.total_components' "$MANIFEST")
UNIMPL=$(jq '.unimplemented_spec_areas | length' "$MANIFEST")
FULL=$(jq '.summary.full_compliance' "$MANIFEST")
PARTIAL=$(jq '.summary.partial_compliance' "$MANIFEST")
MINIMAL=$(jq '.summary.minimal_compliance' "$MANIFEST")

COMPONENT_SUM=$((FULL + PARTIAL + MINIMAL))
if [ "$COMPONENT_SUM" -ne "$EXPECTED_TOTAL" ]; then
  echo "  WARNING: Component count ($EXPECTED_TOTAL) != full($FULL) + partial($PARTIAL) + minimal($MINIMAL) = $COMPONENT_SUM" >&2
  WARNINGS=$((WARNINGS + 1))
fi
if [ "$SUMMARY_TOTAL" -ne "$EXPECTED_TOTAL" ]; then
  echo "  WARNING: summary.total_components ($SUMMARY_TOTAL) != actual components ($EXPECTED_TOTAL)" >&2
  WARNINGS=$((WARNINGS + 1))
fi

echo ""
echo "Manifest: $MANIFEST"
echo "Spec version: $(jq -r '.spec_version' "$MANIFEST")"
echo "Components: $TOTAL"
echo "Errors: $ERRORS, Warnings: $WARNINGS"

if [ "$ERRORS" -gt 0 ]; then
  exit 1
fi
exit 0
