#!/bin/bash
# Admiral Framework — SO Enforcement Completeness Report (SO-17)
# Maps each SO to enforcement mechanism(s), reports type and coverage.
# Produces human-readable summary and JSON output.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"

MAP_FILE="$PROJECT_ROOT/admiral/docs/standing-orders-enforcement-map.json"

if [ ! -f "$MAP_FILE" ]; then
  echo "ERROR: Enforcement map not found at $MAP_FILE" >&2
  exit 1
fi

# Count enforcement types
TOTAL=$(jq '.summary.total_standing_orders' "$MAP_FILE" | tr -d '\r')
HOOK_ENFORCED=$(jq '.summary.hook_enforced' "$MAP_FILE" | tr -d '\r')
COVERAGE=$(jq '.summary.coverage_percentage' "$MAP_FILE" | tr -d '\r')

# Verify all SOs have enforcement function in so_enforcement.sh
SO_LIB="$PROJECT_ROOT/admiral/lib/so_enforcement.sh"
FUNCTIONS_DEFINED=0
if [ -f "$SO_LIB" ]; then
  for i in $(seq -w 1 16); do
    if grep -q "so_${i}_" "$SO_LIB" 2>/dev/null; then
      FUNCTIONS_DEFINED=$((FUNCTIONS_DEFINED + 1))
    fi
  done
fi

# Verify hook files exist for hook-enforced SOs
HOOKS_PRESENT=0
HOOKS_MISSING=0
while IFS= read -r hook_name; do
  hook_name=$(echo "$hook_name" | tr -d '\r"')
  [ -z "$hook_name" ] && continue
  if [ -f "$PROJECT_ROOT/.hooks/$hook_name" ]; then
    HOOKS_PRESENT=$((HOOKS_PRESENT + 1))
  else
    HOOKS_MISSING=$((HOOKS_MISSING + 1))
  fi
done < <(jq -r '.standing_orders[].hooks[]?.name' "$MAP_FILE" | tr -d '\r')

# Critical gaps
CRITICAL_GAPS=$(jq '[.standing_orders[] | select(.coverage == "critical_gap")] | length' "$MAP_FILE" | tr -d '\r')

# Build report
echo "Standing Orders Enforcement Completeness Report" >&2
echo "================================================" >&2
echo "" >&2
echo "Total Standing Orders: $TOTAL" >&2
echo "Hook-enforced: $HOOK_ENFORCED ($COVERAGE%)" >&2
echo "Enforcement functions defined: $FUNCTIONS_DEFINED/16" >&2
echo "Hook files present: $HOOKS_PRESENT" >&2
echo "Hook files missing: $HOOKS_MISSING" >&2
echo "Critical gaps: $CRITICAL_GAPS" >&2
echo "" >&2

# Per-SO status
jq -r '.standing_orders[] | "  \(.id) [\(.enforcement_type)] \(.title) — \(.coverage)"' "$MAP_FILE" | tr -d '\r' >&2

echo "" >&2
echo "================================================" >&2

# JSON output
jq -n --argjson total "$TOTAL" \
      --argjson hook_enforced "$HOOK_ENFORCED" \
      --argjson coverage "$COVERAGE" \
      --argjson functions "$FUNCTIONS_DEFINED" \
      --argjson hooks_present "$HOOKS_PRESENT" \
      --argjson hooks_missing "$HOOKS_MISSING" \
      --argjson critical_gaps "$CRITICAL_GAPS" \
      '{
        total_standing_orders: $total,
        hook_enforced: $hook_enforced,
        coverage_percentage: $coverage,
        enforcement_functions: $functions,
        hooks_present: $hooks_present,
        hooks_missing: $hooks_missing,
        critical_gaps: $critical_gaps,
        completeness: (if $functions == 16 and $hooks_missing == 0 then "complete" else "incomplete" end)
      }'
